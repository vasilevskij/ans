# SSH Hardening Configuration
# Generated by Ansible — {{ ansible_date_time.iso8601 }}
# Host: {{ inventory_hostname }}

Protocol 2

# ── Аутентификация ────────────────────────────────────────────
PermitRootLogin {{ ssh_permit_root_login | default('without-password') }}
PasswordAuthentication {{ ssh_password_auth | default('no') }}
PubkeyAuthentication {{ ssh_pubkey_auth | default('yes') }}
PermitEmptyPasswords no
ChallengeResponseAuthentication no
KerberosAuthentication no
GSSAPIAuthentication no

# ── Безопасность ─────────────────────────────────────────────
X11Forwarding {{ ssh_x11_forwarding | default('no') }}
AllowTcpForwarding {{ ssh_tcp_forwarding | default('yes') }}
AllowAgentForwarding {{ ssh_agent_forwarding | default('yes') }}

# ── Соединение ────────────────────────────────────────────────
ClientAliveInterval {{ ssh_client_alive_interval | default(300) }}
ClientAliveCountMax {{ ssh_client_alive_count_max | default(2) }}
MaxAuthTries {{ ssh_max_auth_tries | default(3) }}
MaxSessions {{ ssh_max_sessions | default(10) }}
LoginGraceTime {{ ssh_login_grace_time | default(60) }}

# ── Шифрование ───────────────────────────────────────────────
KexAlgorithms curve25519-sha256@libssh.org,ecdh-sha2-nistp521,ecdh-sha2-nistp384,ecdh-sha2-nistp256,diffie-hellman-group-exchange-sha256
Ciphers chacha20-poly1305@openssh.com,aes256-gcm@openssh.com,aes128-gcm@openssh.com,aes256-ctr,aes192-ctr,aes128-ctr
MACs hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com,umac-128-etm@openssh.com,hmac-sha2-512,hmac-sha2-256

# ── Логирование ──────────────────────────────────────────────
SyslogFacility AUTH
LogLevel {{ ssh_log_level | default('INFO') }}

# ── Контроль доступа ─────────────────────────────────────────
{% if ssh_allow_users is defined and ssh_allow_users != '*' %}
AllowUsers {{ ssh_allow_users }}
{% endif %}
{% if ssh_allow_groups is defined and ssh_allow_groups != '*' %}
AllowGroups {{ ssh_allow_groups }}
{% endif %}
{% if ssh_deny_users is defined and ssh_deny_users | length > 0 %}
DenyUsers {{ ssh_deny_users }}
{% endif %}
{% if ssh_deny_groups is defined and ssh_deny_groups | length > 0 %}
DenyGroups {{ ssh_deny_groups }}
{% endif %}
